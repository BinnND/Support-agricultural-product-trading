<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:title="Nhập thông tin sản phẩm"
        app:titleTextColor="#1A1A2E"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="#4A90E2"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Tên sản phẩm -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTenSanPham"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTenSanPham"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:hint="Tên sản phẩm *"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Danh mục -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDanhMuc"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Danh mục *">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actDanhMuc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:inputType="none"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Giá & đơn vị -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGiaBan"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:hint="Giá bán *">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGiaBan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:minHeight="48dp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDonVi"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:hint="Đơn vị *">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDonVi"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="kg/bó/mớ"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Tồn kho -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilStock"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Số lượng tồn kho">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:hint="0"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Chứng nhận -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilChungNhan"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Chứng nhận (Tùy chọn)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etChungNhan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Vùng trồng -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFarmingRegion"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Vùng trồng (Tùy chọn)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFarmingRegion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phương pháp canh tác -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFarmingMethod"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Phương pháp canh tác (Tùy chọn)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFarmingMethod"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mô tả -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMoTa"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Mô tả sản phẩm">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMoTa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="3"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Thiếu thông tin bắt buộc!"
                android:textColor="#E53935"
                android:textSize="14sp"
                android:gravity="center"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTiepTheo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="Tiếp theo"
                android:textColor="#FFFFFF"
                app:backgroundTint="#4A90E2"
                app:cornerRadius="10dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>