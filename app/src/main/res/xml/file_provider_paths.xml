<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">    <!-- Ảnh chụp lưu trong cache nội bộ -->
    <cache-path name="camera_images" path="images/" />
    <!-- Ảnh lưu trong files dir -->
    <files-path name="app_images" path="images/" />
    <!-- Ảnh lưu trong external cache -->
    <external-cache-path name="external_camera" path="." />

    <external-files-path
        name="images"
        path="Pictures/" />

</paths>
